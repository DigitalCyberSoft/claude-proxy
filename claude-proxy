# ---------------------------------------------------------------------------
# Logging setup
# ---------------------------------------------------------------------------

log = logging.getLogger("claude-proxy")


def setup_logging(verbose: bool = False) -> None:
    log_dir = Path.home() / ".claude-proxy"
    log_dir.mkdir(exist_ok=True)
    log_file = log_dir / "proxy.log"

    handler = logging.handlers.RotatingFileHandler(
        log_file, maxBytes=1_000_000, backupCount=3
    )
    formatter = logging.Formatter(
        "%(asctime)s %(levelname)s %(message)s", datefmt="%Y-%m-%d %H:%M:%S"
    )
    handler.setFormatter(formatter)

    log.addHandler(handler)
    log.setLevel(logging.DEBUG if verbose else logging.INFO)


# ---------------------------------------------------------------------------
# Patch loading and application
# ---------------------------------------------------------------------------


def load_patches() -> list[dict]:
    script_dir = Path(__file__).resolve().parent

    # Load base patches (patches.json or built-in defaults)
    patches_file = script_dir / "patches.json"
    if patches_file.is_file():
        log.info("Loading patches from %s", patches_file)
        with open(patches_file) as f:
            patches = json.load(f)
        log.info("Loaded %d patches from patches.json", len(patches))
    else:
        patches = list(DEFAULT_PATCHES)
        log.info("Using %d built-in default patches", len(patches))

    # Append user's local patches (not tracked in git, survives updates)
    local_file = script_dir / "patches.local.json"
    if local_file.is_file():
        with open(local_file) as f:
            local = json.load(f)
        if local:
            patches.extend(local)
            log.info("Loaded %d local patches from patches.local.json", len(local))
    else:
        # Create a skeleton so users know the file exists
        with open(local_file, "w") as f:
            f.write("[\n]\n")
        log.info("Created empty patches.local.json — add your own patches here")

    return patches


def apply_patches(text: str, patches: list[dict]) -> tuple[str, int]:
    """Apply replace patches to text. Returns (modified_text, count_applied)."""
    applied = 0
    for p in patches:
        if "old" not in p:
            continue  # skip add-type patches here
        old = p["old"]
        if old in text:
            text = text.replace(old, p["new"])
            applied += 1
            log.debug("  Applied: %s", p["label"])
        else:
            log.debug("  Skipped (not found): %s", p["label"])
    return text, applied


def apply_add_patches(system_text: str, patches: list[dict]) -> tuple[str, int]:
    """Apply add-type patches. Appends text if the 'unless' string is absent.

    Patch format:
        {
            "label": "...",
            "add": "text to inject",
            "unless": "don't add if this string is already present"
        }

    The 'unless' field prevents duplicates. If omitted, the 'add' text
    itself is used as the duplicate check.
    """
    applied = 0
    for p in patches:
        if "add" not in p:
            continue  # skip replace-type patches here
        check = p.get("unless", p["add"])
        if check in system_text:
            log.debug("  Skipped (already present): %s", p["label"])
            continue
        system_text = system_text + "\n\n" + p["add"]
        applied += 1
        log.debug("  Injected: %s", p["label"])
    return system_text, applied


def rewrite_body(body: bytes, patches: list[dict]) -> tuple[bytes, int]:
    """Parse JSON body, patch the system field, return (modified_bytes, count)."""
    data = json.loads(body)
    system = data.get("system")
    if system is None:
        return body, 0

    total_applied = 0

    if isinstance(system, str):
        data["system"], count = apply_patches(system, patches)
        total_applied += count
        data["system"], count = apply_add_patches(data["system"], patches)
        total_applied += count
    elif isinstance(system, list):
        # Replace patches run on every text block
        for block in system:
            if isinstance(block, dict) and block.get("type") == "text":
                block["text"], count = apply_patches(block["text"], patches)
                total_applied += count

        # Add patches inject into the largest text block (the main prompt)
        add_patches = [p for p in patches if "add" in p]
        if add_patches:
            biggest = max(
                (b for b in system if isinstance(b, dict) and b.get("type") == "text"),
                key=lambda b: len(b.get("text", "")),
                default=None,
            )
            if biggest is not None:
                biggest["text"], count = apply_add_patches(biggest["text"], add_patches)
                total_applied += count

    return json.dumps(data, ensure_ascii=False).encode(), total_applied


# ---------------------------------------------------------------------------
# Prompt version logging — captures the raw system prompt once per version
# ---------------------------------------------------------------------------

import re

_PROMPT_DIR = Path.home() / ".claude-proxy" / "prompts"


def _parse_version(user_agent: str) -> str | None:
    """Extract version from 'claude-cli/2.1.110 (external, sdk-cli)'."""
    m = re.match(r"claude-cli/([\d.]+)", user_agent or "")
    return m.group(1) if m else None


def _log_prompt_if_new(version: str, body: bytes) -> str:
    """Save each unique system prompt to disk, keyed by version + content hash.
    Different API calls carry different prompts (title gen, main conversation,
    explore agent, etc.) — we keep them all.
    Returns a short status string for logging."""
    import hashlib

    try:
        data = json.loads(body)
    except (json.JSONDecodeError, UnicodeDecodeError):
        return "skipped (body not valid JSON)"

    system = data.get("system")
    if system is None:
        return "skipped (no system field)"

    # Hash the system content to deduplicate
    system_bytes = json.dumps(system, ensure_ascii=False, sort_keys=True).encode()
    content_hash = hashlib.sha256(system_bytes).hexdigest()[:8]

    prompt_file = _PROMPT_DIR / f"v{version}_{content_hash}.json"
    if prompt_file.exists():
        return f"skipped (already on disk: {content_hash})"

    # Extract system prompt blocks (pre-patch, this is the original text)
    if isinstance(system, str):
        prompt_data = {"text": system}
        system_chars = len(system)
    elif isinstance(system, list):
        prompt_data = {"blocks": system}
        system_chars = sum(
            len(b.get("text", "")) for b in system if isinstance(b, dict)
        )
    else:
        return f"skipped (system type: {type(system).__name__})"

    import datetime

    prompt_data["version"] = version
    prompt_data["model"] = data.get("model")
    prompt_data["system_chars"] = system_chars
    prompt_data["content_hash"] = content_hash
    prompt_data["captured"] = datetime.datetime.now().isoformat(timespec="seconds")

    _PROMPT_DIR.mkdir(parents=True, exist_ok=True)
    with open(prompt_file, "w") as f:
        json.dump(prompt_data, f, indent=2, ensure_ascii=False)

    return f"saved {system_chars} chars -> {prompt_file.name}"


_http_client: "httpx.Client | None" = None
_banner_shown = False
_banner_lock = threading.Lock()


# ---------------------------------------------------------------------------
# Proxy handler
# ---------------------------------------------------------------------------


class ProxyHandler(http.server.BaseHTTPRequestHandler):
    patches: list[dict] = []

    def _proxy(self) -> None:
        import time

        t0 = time.monotonic()

        # Read request body if present
        content_length = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(content_length) if content_length > 0 else b""

        # Rewrite system prompt for POST /v1/messages
        is_messages = self.command == "POST" and self.path.startswith("/v1/messages")
        patch_count = 0
        system_size = 0
        if is_messages and body:
            # Log the raw prompt BEFORE patching, once per version
            try:
                ua = self.headers.get("User-Agent", "")
                version = _parse_version(ua)
                if version:
                    result = _log_prompt_if_new(version, body)
                    log.info("Prompt log v%s: %s", version, result)
                else:
                    log.debug("No version in User-Agent: %s", ua[:80])
            except Exception:
                log.exception("Failed to log prompt version")

            system_size = len(body)

            try:
                body, patch_count = rewrite_body(body, self.patches)
            except Exception:
                log.exception("Failed to rewrite request body, forwarding unchanged")

        # Build upstream headers — skip hop-by-hop, fix Host and Content-Length
        fwd_headers = {}
        for key, value in self.headers.items():
            lower = key.lower()
            if lower in ("host", "connection", "keep-alive", "transfer-encoding"):
                continue
            if lower == "content-length":
                fwd_headers[key] = str(len(body))
            else:
                fwd_headers[key] = value
        fwd_headers["Host"] = UPSTREAM_HOST
        if body:
            fwd_headers["Content-Length"] = str(len(body))

        # Forward to Anthropic via httpx (HTTP/2, persistent connections,
        # connection pooling, keepalive — all handled automatically).
        url = f"https://{UPSTREAM_HOST}{self.path}"
        try:
            upstream = _http_client.send(
                _http_client.build_request(
                    self.command, url,
                    headers=fwd_headers,
                    content=body or None,
                ),
                stream=True,
            )
        except Exception:
            elapsed = time.monotonic() - t0
            log.exception(
                "%s %s -> 502 (upstream error) %.1fs", self.command, self.path, elapsed
            )
            self.send_error(502, "Bad Gateway")
            return

        elapsed = time.monotonic() - t0
        if is_messages:
            log.info(
                "%s %s -> %d (patched %d/%d) %.1fs",
                self.command,
                self.path,
                upstream.status_code,
                patch_count,
                len(self.patches),
                elapsed,
            )
            # Show a one-time banner on the first main conversation request
            # (system_size > 50K distinguishes it from title-gen and other
            # small internal calls that carry fewer prompt components).
            global _banner_shown
            if patch_count > 0 and system_size > 50000 and not _banner_shown:
                with _banner_lock:
                    if not _banner_shown:
                        _banner_shown = True
                        print(
                            f"\033[90mclaude-proxy: {patch_count}/{len(self.patches)}"
                            f" patches applied\033[0m",
                            file=sys.stderr, flush=True,
                        )
        else:
            log.info(
                "%s %s -> %d %.1fs",
                self.command, self.path, upstream.status_code, elapsed,
            )

        # Stream response back to the client over HTTP/1.1.
        # httpx gives us decoded bytes; we re-chunk for the HTTP/1.1 client.
        try:
            self.send_response_only(upstream.status_code)
            # Forward response headers, skip HTTP/2 pseudo-headers
            for key, value in upstream.headers.multi_items():
                lower = key.lower()
                if lower in ("connection", "keep-alive", "transfer-encoding"):
                    continue
                self.send_header(key, value)
            self.send_header("Transfer-Encoding", "chunked")
            self.end_headers()

            for chunk in upstream.iter_raw():
                if not chunk:
                    continue
                self.wfile.write(f"{len(chunk):x}\r\n".encode())
                self.wfile.write(chunk)
                self.wfile.write(b"\r\n")
                self.wfile.flush()
            self.wfile.write(b"0\r\n\r\n")
            self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError, ConnectionAbortedError):
            pass  # client disconnected
        finally:
            upstream.close()

    # Route all HTTP methods through _proxy
    do_GET = _proxy
    do_POST = _proxy
    do_PUT = _proxy
    do_DELETE = _proxy
    do_PATCH = _proxy
    do_HEAD = _proxy
    do_OPTIONS = _proxy

    # Redirect BaseHTTPRequestHandler's default stderr logging to our logger
    def log_message(self, format, *args):
        log.debug(format, *args)


