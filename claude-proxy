if IS_WINDOWS:
    NPM_VERSIONS_DIR = Path(os.environ.get("APPDATA", Path.home() / "AppData/Roaming")) / "claude-npm/node_modules/@anthropic-ai/claude-code"
else:
    NPM_VERSIONS_DIR = Path.home() / ".local/share/claude-npm/node_modules/@anthropic-ai/claude-code"


def find_claude_bin(requested_version: str | None = None) -> tuple[str, list[str]]:
    """Resolve the claude binary to use.
    Returns (binary_path, prefix_args) where prefix_args is empty for
    native binaries and ['node', 'cli.js'] for npm installs.
    """
    if requested_version:
        # Check for npm-installed version
        cli_js = NPM_VERSIONS_DIR / "cli.js"
        if cli_js.is_file():
            pkg_json = NPM_VERSIONS_DIR / "package.json"
            if pkg_json.is_file():
                with open(pkg_json) as f:
                    installed_ver = json.load(f).get("version", "")
                if installed_ver != requested_version:
                    npm_prefix = NPM_VERSIONS_DIR.parent.parent.parent
                    print(
                        f"Error: requested v{requested_version} but npm has "
                        f"v{installed_ver}. Run:\n"
                        f"  npm install --prefix \"{npm_prefix}\" "
                        f"@anthropic-ai/claude-code@{requested_version}",
                        file=sys.stderr,
                    )
                    sys.exit(1)
            node_bin = shutil.which("node")
            if not node_bin:
                print("Error: 'node' not found in PATH", file=sys.stderr)
                sys.exit(1)
            return node_bin, [str(cli_js)]
        else:
            npm_prefix = NPM_VERSIONS_DIR.parent.parent.parent
            print(
                f"Error: npm install not found. Run:\n"
                f"  npm install --prefix \"{npm_prefix}\" "
                f"@anthropic-ai/claude-code@{requested_version}",
                file=sys.stderr,
            )
            sys.exit(1)

    # Default: use native claude from PATH
    claude_bin = shutil.which("claude")
    if not claude_bin:
        print("Error: 'claude' not found in PATH", file=sys.stderr)
        sys.exit(1)
    return claude_bin, []


def main() -> None:
    # Parse our own flags, pass the rest to claude
    verbose = "--verbose" in sys.argv
    claude_version = None
    claude_args = []
    for a in sys.argv[1:]:
        if a == "--verbose":
            continue
        if a.startswith("--claude-version="):
            claude_version = a.split("=", 1)[1]
            continue
        claude_args.append(a)

    setup_logging(verbose)

    # Find claude binary
    claude_bin, prefix_args = find_claude_bin(claude_version)
    if claude_version:
        log.info("Using npm Claude Code v%s: %s", claude_version, claude_bin)

    # If settings.json has effortLevel "high" and the user didn't already
    # pass --effort, escalate to --effort max.
    if "--effort" not in " ".join(claude_args):
        settings_file = Path.home() / ".claude" / "settings.json"
        try:
            if settings_file.is_file():
                with open(settings_file) as f:
                    settings = json.load(f)
                if settings.get("effortLevel") == "high":
                    claude_args = ["--effort", "max"] + claude_args
                    log.info("effortLevel=high in settings, added --effort max")
        except (json.JSONDecodeError, OSError):
            pass

    # Load patches
    patches = load_patches()
    ProxyHandler.patches = patches

    # Start HTTP server on dynamic port.
    # Override handle_error to suppress noisy tracebacks when the client
    # disconnects mid-request (ConnectionResetError, BrokenPipeError).
    class QuietHTTPServer(http.server.HTTPServer):
        def handle_error(self, request, client_address):
            exc_type = sys.exc_info()[0]
            if exc_type in (BrokenPipeError, ConnectionResetError,
                            ConnectionAbortedError):
                log.debug("Client %s disconnected", client_address[0])
            else:
                log.exception("Error handling request from %s", client_address[0])

    server = QuietHTTPServer(("127.0.0.1", 0), ProxyHandler)
    port = server.server_address[1]
    log.info("Proxy started on 127.0.0.1:%d (pid %d)", port, os.getpid())

    # httpx client — HTTP/2, persistent connection pool, automatic keepalive.
    # No manual ping thread needed; httpx manages connection lifecycle.
    import httpx

    global _http_client
    _http_client = httpx.Client(
        http2=True,
        timeout=httpx.Timeout(connect=10.0, read=600.0, write=60.0, pool=10.0),
    )

    server_thread = threading.Thread(target=server.serve_forever, daemon=True)
    server_thread.start()

    # Set up signal forwarding BEFORE spawning claude to avoid a race
    # where SIGINT arrives between spawn and handler registration.
    proc = None

    if IS_WINDOWS:
        # On Windows, Ctrl+C sends CTRL_C_EVENT to all processes sharing
        # the console. We spawn claude in a new process group so only we
        # receive it, then forward explicitly via CTRL_C_EVENT.
        def forward_signal(signum, _frame):
            if proc is not None:
                try:
                    os.kill(proc.pid, signal.CTRL_C_EVENT)
                except (ProcessLookupError, OSError):
                    pass

        signal.signal(signal.SIGINT, forward_signal)
        try:
            signal.signal(signal.SIGBREAK, forward_signal)
        except (AttributeError, OSError):
            pass

        creation_flags = subprocess.CREATE_NEW_PROCESS_GROUP
    else:
        def forward_signal(signum, _frame):
            if proc is not None:
                try:
                    proc.send_signal(signum)
                except ProcessLookupError:
                    pass

        signal.signal(signal.SIGINT, forward_signal)
        signal.signal(signal.SIGTERM, forward_signal)
        creation_flags = 0

    # Spawn claude with ANTHROPIC_BASE_URL pointing at our proxy
    env = os.environ.copy()
    env["ANTHROPIC_BASE_URL"] = f"http://127.0.0.1:{port}"

    proc = subprocess.Popen(
        [claude_bin] + prefix_args + claude_args,
        env=env,
        stdin=sys.stdin,
        stdout=sys.stdout,
        stderr=sys.stderr,
        creationflags=creation_flags,
    )

    # Wait for claude to exit
    rc = proc.wait()
    log.info("Claude exited with code %d, shutting down proxy", rc)

    _http_client.close()
    server.shutdown()
    sys.exit(rc)


if __name__ == "__main__":
    main()
