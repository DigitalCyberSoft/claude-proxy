#!/usr/bin/env python3
"""claude-proxy: Per-session prompt-rewriting proxy for Claude Code.

Starts a local HTTP proxy that rewrites system prompt strings in API requests,
then launches claude through it. Proxy lives exactly as long as the claude session.

Usage:
    ./claude-proxy [any claude args]                   # Linux/Mac
    python claude-proxy [any claude args]              # Windows
    ./claude-proxy --verbose                           # debug logging
    ./claude-proxy --claude-version=2.1.98             # use npm-installed version
"""

import http.server
import json
import logging
import logging.handlers
import os
import shutil
import signal
import subprocess
import sys
import threading
from pathlib import Path

IS_WINDOWS = sys.platform == "win32"

# Enable ANSI escape sequences on Windows so Claude Code's TUI
# (colors, spinners, cursor movement) renders correctly.
if IS_WINDOWS:
    try:
        import ctypes
        kernel32 = ctypes.windll.kernel32
        # STD_OUTPUT_HANDLE = -11, ENABLE_VIRTUAL_TERMINAL_PROCESSING = 0x4
        handle = kernel32.GetStdHandle(-11)
        mode = ctypes.c_ulong()
        kernel32.GetConsoleMode(handle, ctypes.byref(mode))
        kernel32.SetConsoleMode(handle, mode.value | 0x4)
    except Exception:
        pass

